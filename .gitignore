outputs/density_maps/

# Model checkpoints
checkpoints/

# Video outputs
outputs/video/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Conda / virtualenv
.env
.venv
env/
venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# macOS
.DS_Store
.AppleDouble
.LSOverride

