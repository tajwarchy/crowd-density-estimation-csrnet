# outputs/evaluation/*.csv

# Plots and figures (optional — keep if you want portfolio visuals in repo)
# outputs/evaluation/*.png

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# IDE
.vscode/
.idea/
*.swp
*.swo